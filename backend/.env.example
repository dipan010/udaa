# Google Cloud (Firestore Only)
GOOGLE_CLOUD_PROJECT=some_project_id
GOOGLE_API_KEY=some_api_key

# Firestore
FIRESTORE_COLLECTION=sessions

# Gemini Models
COMPUTER_USE_MODEL=gemini-2.5-computer-use-preview-10-2025
LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Browser / Screen
SCREEN_WIDTH=1440
SCREEN_HEIGHT=900

# Agent
MAX_AGENT_TURNS=25
AGENT_TIMEOUT_SECONDS=300

# Local Storage
LOCAL_SCREENSHOT_DIR=screenshots

